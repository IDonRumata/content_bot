# ============================================================
# CONTENT BOT — ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in all values
# NEVER commit .env to version control
# ============================================================

# --- Telegram ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram user ID (get from @userinfobot)
ADMIN_TELEGRAM_ID=123456789

# Your Telegram channel ID where posts will be published (e.g. -1001234567890)
TELEGRAM_CHANNEL_ID=-1001234567890

# Editors — may review/edit/approve posts but NOT manage bloggers/config.
# Comma-separated Telegram user IDs. Leave empty for none.
EDITOR_TELEGRAM_IDS=

# Secret token for Telegram webhook verification (random 32+ char string)
TELEGRAM_WEBHOOK_SECRET=generate_random_secret_here

# --- Claude AI ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- YouTube Data API v3 ---
# Get from https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# --- Transcript proxy (residential) ---
# YouTube blocks the captions endpoint from datacenter/VPS IPs, so fetching
# transcripts needs a residential proxy. Webshare is officially integrated with
# youtube-transcript-api. Sign up at https://www.webshare.io → buy "Residential"
# (NOT "Proxy Server"/datacenter) → Dashboard → copy "Proxy Username"/"Password".
# Leave empty to disable transcripts (bot falls back to title+description).
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
# Optional: any other residential/mobile HTTP proxy, used only if Webshare is
# unset. Format: http://user:pass@host:port
TRANSCRIPT_PROXY_URL=

# --- Meta Threads API ---
# Get from https://developers.facebook.com → Threads API
THREADS_USER_ID=your_threads_user_id_here
THREADS_ACCESS_TOKEN=your_threads_long_lived_access_token_here

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./content_bot.db

# --- Security ---
# Secret key for encrypting sensitive data in DB (generate with: openssl rand -hex 32)
SECRET_KEY=generate_64_char_hex_here

# Max requests per user per minute (rate limiting)
RATE_LIMIT_PER_MINUTE=20

# --- Sentry (optional, for error tracking) ---
SENTRY_DSN=

# --- Scheduler ---
# How often to check for new content (in hours)
SCRAPE_INTERVAL_HOURS=12

# Max posts to collect per scrape run
MAX_POSTS_PER_RUN=5

# Minimum views for a video to be considered "popular"
MIN_VIEWS_THRESHOLD=30000

# Only consider videos published within this many days (keeps content fresh)
SCRAPE_RECENT_DAYS=30

# Skip a candidate if the same topic was posted within this many days
TOPIC_DEDUP_DAYS=45

# Skip videos with less source content than this (transcript+description chars).
# Filters out ads/shorts that would otherwise be rewritten "from thin air".
MIN_SOURCE_CHARS=220

# --- Posting queue ---
# Delay between posts in queue (in hours)
POST_INTERVAL_HOURS=24

# --- App ---
# Set to "production" for webhook mode, "polling" for local dev
BOT_MODE=polling

# Public HTTPS URL for webhook (required if BOT_MODE=production)
# WEBHOOK_URL=https://yourdomain.com/webhook
